# Application
NODE_ENV=production
PORT=4000

# Database
MONGODB_URI=mongodb://mongodb:27017/scanbell
REDIS_URL=redis://redis:6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-replace-in-production
JWT_EXPIRATION=24h

# Encryption
ENCRYPTION_SECRET=your-super-secret-encryption-key-replace-in-production

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# API Configuration
API_RATE_LIMIT=100
API_RATE_WINDOW=15m

# Frontend
REACT_APP_API_URL=https://api.scanbell.com
REACT_APP_WS_URL=wss://ws.scanbell.com

# ML Service
ML_MODEL_PATH=/models
CUDA_VISIBLE_DEVICES=0

# Monitoring
PROMETHEUS_RETENTION_DAYS=15
GRAFANA_ADMIN_PASSWORD=your-secure-admin-password

# SSL Certificates
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/scanbell.crt
SSL_CERTIFICATE_KEY_PATH=/etc/nginx/ssl/scanbell.key

# Security
ALLOWED_ORIGINS=https://scanbell.com,https://www.scanbell.com
CORS_MAX_AGE=86400

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Backup
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/backups

# Feature Flags
ENABLE_FACE_RECOGNITION=true
ENABLE_SMART_HOME=true
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true

# Performance
MAX_UPLOAD_SIZE=10mb
COMPRESSION_LEVEL=6
CACHE_TTL=3600

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
WS_TIMEOUT=60000

# Device Configuration
CAMERA_QUALITY=high
MOTION_SENSITIVITY=medium
ALERT_THRESHOLD=3
